# ── sys-monitor landing page ──────────────────────────────────────
# Clean URL routing for Apache

RewriteEngine On

# Force HTTPS (uncomment if your host supports SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except for root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# If the request maps to an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URLs: /docs -> /docs/index.html
RewriteRule ^docs$ docs/index.html [L]

# Clean URLs: /privacy -> /privacy/index.html
RewriteRule ^privacy$ privacy/index.html [L]

# Custom error pages (optional)
ErrorDocument 404 /index.html

# ── Caching ──────────────────────────────────────────────────────

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
</IfModule>

# ── Compression ──────────────────────────────────────────────────

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# ── Security headers ────────────────────────────────────────────

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
